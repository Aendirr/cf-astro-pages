---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import PostCard from '@/components/PostCard.astro';
import Newsletter from '@/components/Newsletter.astro';
import Pagination from '@/components/Pagination.astro';
import { api } from '@/lib/api';
import { buildUrl, getCacheHeaders, getSiteLanguage, t } from '@/lib/utils';

const settings = await api.getSettings();
const siteLang = getSiteLanguage(settings);
const [featuredResponse, latestResponse] = await Promise.all([
  api.getPosts({ lang: siteLang, page: 1, limit: 12 }),
  api.getPosts({ lang: siteLang, page: 1, limit: 12 }),
]);

const featuredPosts = featuredResponse.data.filter((post) => post.featured).slice(0, 3);
const latestPosts = latestResponse.data;
const totalPages = Math.ceil(latestResponse.total / latestResponse.limit);
Astro.response.headers.set('Cache-Control', getCacheHeaders('list')['Cache-Control']);
---

<BaseLayout
  lang={siteLang}
  settings={settings}
  seo={{
    title: settings.seoTitle || settings.siteName,
    description: settings.seoDescription || settings.siteDescription,
    canonical: buildUrl(),
    xDefaultHref: buildUrl(),
    image: settings.ogImageUrl,
    type: 'website',
    lang: siteLang,
  }}
  currentPath=""
>
  <Hero
    lang={siteLang}
    title={settings.siteName}
    subtitle={settings.siteDescription}
  />

  {featuredPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-display font-bold text-neutral-900">
          {t(siteLang, 'featuredPosts')}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredPosts.map((post) => (
          <PostCard post={post} lang={siteLang} />
        ))}
      </div>
    </section>
  )}

  <section id="latest-posts" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-display font-bold text-neutral-900">
        {t(siteLang, 'latestPosts')}
      </h2>
    </div>

    {latestPosts.length === 0 ? (
      <div class="text-center py-12">
        <p class="text-neutral-600 text-lg">{t(siteLang, 'noPosts')}</p>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestPosts.map((post) => (
            <PostCard post={post} lang={siteLang} />
          ))}
        </div>
        <Pagination
          currentPage={latestResponse.page}
          totalPages={totalPages}
          baseUrl=""
          lang={siteLang}
        />
      </>
    )}
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Newsletter lang={siteLang} />
  </div>
</BaseLayout>
